{
  "name": "claude-ai-coding-agent-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Claude AI Coding Agent - Desktop Application (TypeScript)",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "start": "cd electron && npm run start",
    "build:electron": "cd electron && npm run build",
    "dev:electron": "cd electron && npm run dev"
  },
  "dependencies": {
    "claude-ai-coding-agent": "file:.."
  }
}
